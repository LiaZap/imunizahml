# ──────────────────────────────────────────────────────────────────────────
# CREDENCIAIS DE TESTE — copie para .env.test.local e preencha
# .env.test.local é gitignored, não vai pro GitHub
# ──────────────────────────────────────────────────────────────────────────

# 🔑 OPENAI — chave de teste (pode ser uma com limite baixo)
OPENAI_API_KEY=sk-coloque-aqui

# 🤖 Modelo a testar
# Opções: gpt-4o, gpt-4.1, gpt-4.1-mini, gpt-4.1-nano
MODEL=gpt-4.1

# 📱 UAZAPI — credenciais da instância
UAZAPI_URL=https://liaautomacoes.uazapi.com
UAZAPI_TOKEN=35521eb9-392a-4b60-a1ca-e2069bf2746b

# 📞 Telefones para teste (formato 55DDDNNNNNNNNN, sem + ou espaço)
# Número que vai RECEBER a mensagem (seu celular para testar)
TEST_RECEIVER_PHONE=55519999999999

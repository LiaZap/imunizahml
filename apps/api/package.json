{
  "name": "@imuniza/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/server.ts",
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/server.ts",
    "build": "tsc",
    "start": "tsx src/server.ts",
    "start:prod": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "reindex": "dotenv -e ../../.env -- tsx src/scripts/reindex.ts",
    "ingest:docx": "dotenv -e ../../.env -- tsx src/scripts/ingestDocx.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.1",
    "@fastify/sensible": "^6.0.2",
    "@imuniza/ai": "workspace:*",
    "@imuniza/db": "workspace:*",
    "@imuniza/kb": "workspace:*",
    "@imuniza/shared": "workspace:*",
    "@imuniza/uazapi": "workspace:*",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.35.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "googleapis": "^173.0.0",
    "ioredis": "^5.4.2",
    "jose": "^5.9.6",
    "mammoth": "^1.8.0",
    "openai": "^4.80.0",
    "pdfkit": "^0.15.1",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.5",
    "@types/pdfkit": "^0.13.9",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector, pgcrypto]
}

enum UserRole {
  admin
  attendant
  secretary
}

enum ConversationStatus {
  active
  awaiting_handoff
  assigned
  closed
}

enum MessageRole {
  user
  assistant
  system
  tool
  human
}

enum HandoffStatus {
  pending
  assigned
  resolved
  cancelled
}

enum ReminderStatus {
  scheduled
  sent
  failed
  cancelled
}

enum CampaignStatus {
  draft
  scheduled
  running
  completed
  failed
}

enum CampaignAudience {
  all
  baby_below_12m
  missing_next_dose
  custom
}

enum AppointmentStatus {
  scheduled
  attended
  no_show
  paid
  cancelled
}

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  phone     String?
  config    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  patients        Patient[]
  conversations   Conversation[]
  kbDocuments     KBDocument[]
  vaccines        Vaccine[]
  packages        VaccinePackage[]
  handoffs        Handoff[]
  metrics         MetricSnapshot[]
  vaccinations    PatientVaccination[]
  reminders       VaccinationReminder[]
  campaigns       Campaign[]
  appointments    Appointment[]
  cardExtractions VaccineCardExtraction[]

  @@map("tenants")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(attendant)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations Conversation[] @relation("AssignedTo")
  handoffs      Handoff[]      @relation("HandoffAssignee")

  @@index([tenantId])
  @@map("users")
}

model Patient {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  phone     String
  name      String?
  profile   Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations   Conversation[]
  vaccinations    PatientVaccination[]
  reminders       VaccinationReminder[]
  appointments    Appointment[]
  cardExtractions VaccineCardExtraction[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@map("patients")
}

model Conversation {
  id               String             @id @default(uuid()) @db.Uuid
  tenantId         String             @db.Uuid
  patientId        String             @db.Uuid
  status           ConversationStatus @default(active)
  assignedToUserId String?            @db.Uuid
  lastMessageAt    DateTime           @default(now())
  /// Ate este timestamp a IA nao responde (atendente respondeu pelo numero real)
  aiPausedUntil    DateTime?
  metadata         Json               @default("{}")
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient    Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  assignedTo User?     @relation("AssignedTo", fields: [assignedToUserId], references: [id])
  messages   Message[]
  handoffs   Handoff[]

  @@index([tenantId, status])
  @@index([patientId])
  @@index([lastMessageAt])
  @@index([aiPausedUntil])
  @@map("conversations")
}

model Message {
  id             String      @id @default(uuid()) @db.Uuid
  conversationId String      @db.Uuid
  role           MessageRole
  content        String
  metadata       Json        @default("{}")
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

model KBDocument {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  title       String
  source      String
  content     String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chunks KBChunk[]

  @@index([tenantId])
  @@map("kb_documents")
}

model KBChunk {
  id         String                       @id @default(uuid()) @db.Uuid
  documentId String                       @db.Uuid
  content    String
  embedding  Unsupported("vector(1536)")?
  metadata   Json                         @default("{}")
  createdAt  DateTime                     @default(now())

  document KBDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("kb_chunks")
}

model Vaccine {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @db.Uuid
  name             String
  slug             String
  description      String
  ageMonths        Int[]
  priceCash        Decimal  @db.Decimal(10, 2)
  priceInstallment Decimal  @db.Decimal(10, 2)
  installments     Int      @default(3)
  active           Boolean  @default(true)
  /// True quando ha estoque. Quando false, IA informa o paciente que esta em falta
  /// e oferece adicionar à lista de espera (via request_handoff com reason=waitlist).
  inStock          Boolean  @default(true)
  /// Nota opcional exibida na resposta quando inStock=false (ex: "previsao maio/26").
  outOfStockNote   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vaccinations PatientVaccination[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("vaccines")
}

model VaccinePackage {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @db.Uuid
  name             String
  slug             String
  description      String
  items            Json
  priceCash        Decimal  @db.Decimal(10, 2)
  priceInstallment Decimal  @db.Decimal(10, 2)
  installments     Int      @default(5)
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("vaccine_packages")
}

model Handoff {
  id               String        @id @default(uuid()) @db.Uuid
  tenantId         String        @db.Uuid
  conversationId   String        @db.Uuid
  assignedToUserId String?       @db.Uuid
  status           HandoffStatus @default(pending)
  summary          String
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  assignedTo   User?        @relation("HandoffAssignee", fields: [assignedToUserId], references: [id])

  @@index([tenantId, status])
  @@index([conversationId])
  @@map("handoffs")
}

model MetricSnapshot {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  date      DateTime @db.Date
  payload   Json
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, date])
  @@index([tenantId, date])
  @@map("metric_snapshots")
}

model PatientVaccination {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid
  patientId   String    @db.Uuid
  vaccineId   String?   @db.Uuid
  vaccineSlug String
  dose        Int
  appliedAt   DateTime
  nextDueAt   DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  vaccine Vaccine? @relation(fields: [vaccineId], references: [id], onDelete: SetNull)

  @@index([tenantId, patientId])
  @@index([nextDueAt])
  @@map("patient_vaccinations")
}

model VaccinationReminder {
  id           String         @id @default(uuid()) @db.Uuid
  tenantId     String         @db.Uuid
  patientId    String         @db.Uuid
  vaccineSlug  String
  dose         Int
  scheduledFor DateTime
  message      String
  status       ReminderStatus @default(scheduled)
  sentAt       DateTime?
  errorMessage String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, scheduledFor])
  @@index([patientId])
  @@map("vaccination_reminders")
}

model Appointment {
  id              String            @id @default(uuid()) @db.Uuid
  tenantId        String            @db.Uuid
  patientId       String            @db.Uuid
  conversationId  String?           @db.Uuid
  scheduledFor    DateTime
  status          AppointmentStatus @default(scheduled)
  vaccineSlugs    String[]
  expectedValue   Decimal?          @db.Decimal(10, 2)
  paidValue       Decimal?          @db.Decimal(10, 2)
  notes           String?
  createdByUserId String?           @db.Uuid
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([patientId])
  @@index([scheduledFor])
  @@map("appointments")
}

model VaccineCardExtraction {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @db.Uuid
  patientId       String   @db.Uuid
  conversationId  String?  @db.Uuid
  sourceMessageId String?
  extracted       Json
  reviewed        Boolean  @default(false)
  createdAt       DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([tenantId, reviewed])
  @@index([patientId])
  @@map("vaccine_card_extractions")
}

model Campaign {
  id             String           @id @default(uuid()) @db.Uuid
  tenantId       String           @db.Uuid
  name           String
  message        String
  audience       CampaignAudience @default(all)
  audienceFilter Json             @default("{}")
  status         CampaignStatus   @default(draft)
  scheduledFor   DateTime?
  startedAt      DateTime?
  finishedAt     DateTime?
  totalTargets   Int              @default(0)
  sentCount      Int              @default(0)
  failedCount    Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@map("campaigns")
}
